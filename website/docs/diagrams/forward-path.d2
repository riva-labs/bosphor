shape: sequence_diagram

user: User
evm: EVM\nBosphorAdapter
lz: LayerZero DVN
sui: Sui OApp

user -> evm: submitIntent(payload, deadline)
evm -> evm: ABI encode\n(intentId, sender, payload, deadline)
evm -> lz: _lzSend(type 0 message)
lz -> lz: DVN verification\n(2-block confirmation)
lz -> sui: lz_receive()
sui -> sui: Decode message,\nstore IntentRecord
sui -> sui: emit IntentReceived
