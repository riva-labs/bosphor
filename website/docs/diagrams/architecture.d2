direction: right

user: User {
  shape: person
  style.font-size: 16
}

evm: EVM\nBosphorAdapter {
  style.font-size: 16
  style.fill: "#E3E9FD"
  style.font-color: "#333"
}

lz: LayerZero\nDVN Verified {
  shape: cloud
  style.fill: "#E8F0FE"
  style.font-color: "#333"
  style.font-size: 14
}

sui: Sui\nlz_receiver {
  style.font-size: 16
  style.fill: "#E3F2FD"
  style.font-color: "#333"
}

relayer: Relayer {
  shape: hexagon
  style.fill: "#FFF3E0"
  style.font-color: "#333"
  style.font-size: 16
}

walrus: Walrus\nexecute_store {
  shape: cylinder
  style.fill: "#E8F5E9"
  style.font-color: "#333"
  style.font-size: 16
}

# Forward path
user -> evm: 1. submitIntent {style.font-size: 13}
evm -> lz: 2. _lzSend {style.font-size: 13}
lz -> sui: 3. lz_receive {style.font-size: 13}

# Relayer picks up
sui -> relayer: 4. poll events {
  style.stroke-dash: 3
  style.font-size: 13
}

# Storage
relayer -> walrus: 5. store blob {style.font-size: 13}

# Return path
walrus -> lz: 6. lz_send_proof {style.font-size: 13}
lz -> evm: 7. _lzReceive {style.font-size: 13}
