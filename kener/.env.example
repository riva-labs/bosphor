# Kener env for status.bosphor.xyz. Copy to kener/.env (gitignored) and fill in.

# Secret for sessions/CSRF. Generate: openssl rand -base64 32
KENER_SECRET_KEY=

# Public URL Kener is served from. MUST match how you actually reach it, or
# CSRF blocks admin login. During setup that is the direct host URL; at cutover
# switch to https://status.bosphor.xyz and restart.
#   setup:   http://<vps-ip>:3008
#   cutover: https://status.bosphor.xyz
ORIGIN=https://status.bosphor.xyz
