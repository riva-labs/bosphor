{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "liveNow": false,
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["bosphor", "relayer"],
  "time": { "from": "now-24h", "to": "now" },
  "timezone": "",
  "title": "Bosphor Relayer",
  "uid": "bosphor-relayer",
  "version": 1,
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Intent success rate (1h)",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "bosphor-prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.8 },
              { "color": "green", "value": 0.95 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "bosphor-prometheus" },
          "expr": "sum(rate(bosphor_relayer_intents_processed_total{result=\"success\"}[1h])) / sum(rate(bosphor_relayer_intents_processed_total[1h]))"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Sui checkpoint cursor lag",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "bosphor-prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 200 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "bosphor-prometheus" },
          "expr": "bosphor_relayer_checkpoint_cursor_lag"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "WAL balance",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "bosphor-prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 3,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "bosphor-prometheus" },
          "expr": "bosphor_relayer_wal_balance_wal"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "SUI balance",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "bosphor-prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 3,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "green", "value": 2 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "bosphor-prometheus" },
          "expr": "bosphor_relayer_sui_balance_sui"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Intents processed (rate by result)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "bosphor-prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "bosphor-prometheus" },
          "expr": "sum(rate(bosphor_relayer_intents_processed_total[5m])) by (result)",
          "legendFormat": "{{result}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "LayerZero proof send (rate by result)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "bosphor-prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "bosphor-prometheus" },
          "expr": "sum(rate(bosphor_relayer_lz_send_total[5m])) by (result)",
          "legendFormat": "{{result}}"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Walrus upload duration (p50 / p95)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "bosphor-prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "bosphor-prometheus" },
          "expr": "histogram_quantile(0.5, sum(rate(bosphor_relayer_walrus_upload_seconds_bucket[30m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "bosphor-prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(bosphor_relayer_walrus_upload_seconds_bucket[30m])) by (le))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "WAL auto top-up (rate by result)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "bosphor-prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "bosphor-prometheus" },
          "expr": "sum(rate(bosphor_relayer_wal_topup_total[1h])) by (result)",
          "legendFormat": "{{result}}"
        }
      ]
    },
    {
      "id": 9,
      "type": "table",
      "title": "Recent intents (lifecycle)",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 20 },
      "datasource": { "type": "postgres", "uid": "bosphor-postgres" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": { "showHeader": true },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "bosphor-postgres" },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT to_timestamp(created_at/1000) AS \"created\", intent_id, status, sender, blob_id, sui_object_id, jsonb_array_length(hops) AS hops FROM intent_lifecycle ORDER BY created_at DESC LIMIT 50"
        }
      ]
    }
  ]
}
